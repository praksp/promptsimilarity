{
  "name": "prompt-similarity-cursor",
  "version": "1.0.0",
  "description": "Cursor plugin: send prompts to local similarity service, get notifications when others do similar work",
  "repository": {
    "type": "git",
    "url": "https://github.com/praksp/promptsimilarity.git"
  },
  "main": "dist/extension.js",
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "package": "npx vsce package --no-dependencies",
    "test": "jest"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:promptSimilarity.enableIntegration",
    "onCommand:promptSimilarity.disableIntegration",
    "onCommand:promptSimilarity.refreshView",
    "onCommand:promptSimilarity.openLiveSimilar",
    "onView:promptSimilarityView"
  ],
  "contributes": {
    "configuration": {
      "title": "Prompt Similarity",
      "properties": {
        "promptSimilarity.gatewayUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "Base URL of the prompt similarity API gateway"
        },
        "promptSimilarity.orgId": {
          "type": "string",
          "default": "default-org",
          "description": "Organization ID for multi-tenant context"
        },
        "promptSimilarity.userId": {
          "type": "string",
          "default": "",
          "description": "User ID (leave empty to use machine id)"
        }
      }
    },
    "commands": [
      {
        "command": "promptSimilarity.ingestPrompt",
        "title": "Send current selection to Prompt Similarity"
      },
      {
        "command": "promptSimilarity.findSimilar",
        "title": "Find similar prompts"
      },
      {
        "command": "promptSimilarity.enableIntegration",
        "title": "Enable Prompt Similarity integration (agent prompts → service)"
      },
      {
        "command": "promptSimilarity.disableIntegration",
        "title": "Disable Prompt Similarity integration"
      },
      {
        "command": "promptSimilarity.refreshView",
        "title": "Refresh RAG stats and last similar"
      },
      {
        "command": "promptSimilarity.openLiveSimilar",
        "title": "Open Live Similar (type to find similar prompts)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "promptSimilarity",
          "title": "Prompt Similarity",
          "icon": "$(symbol-misc)"
        }
      ]
    },
    "views": {
      "promptSimilarity": [
        {
          "id": "promptSimilarityView",
          "name": "RAG & Similar"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "promptSimilarity.openLiveSimilar",
          "when": "view == promptSimilarityView",
          "group": "navigation"
        },
        {
          "command": "promptSimilarity.enableIntegration",
          "when": "view == promptSimilarityView",
          "group": "navigation"
        },
        {
          "command": "promptSimilarity.refreshView",
          "when": "view == promptSimilarityView",
          "group": "navigation"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.2.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {}
}
